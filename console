#!/usr/bin/env bash
# ClaudeBox Console — live-updating session dashboard.
# Usage: ./console        (live, refreshes every 3s)
#        ./console --once  (print once and exit)
set -euo pipefail

SESSIONS_DIR="${CLAUDE_REPO_DIR:-$HOME/aztec-packages}/.claude/claudebox/sessions"
B='\033[1m' D='\033[2m' G='\033[32m' Y='\033[33m' R='\033[31m' C='\033[36m' X='\033[0m'

render() {
  echo -e "\n${B}ClaudeBox Console${X}"
  echo -e "${D}$(printf '─%.0s' {1..100})${X}"

  if systemctl --user is-active claudebox-slack.service &>/dev/null; then
    echo -e "  Server: ${G}running${X}"
  else
    echo -e "  Server: ${R}stopped${X}"
  fi

  local containers
  containers=$(docker ps --filter "name=claudebox-" --format '{{.Names}}' 2>/dev/null | grep -vc '^claudebox-sidecar' || true)
  echo -e "  Active: ${B}${containers}${X} containers"
  echo ""

  if [ ! -d "$SESSIONS_DIR" ] || [ -z "$(ls -A "$SESSIONS_DIR" 2>/dev/null)" ]; then
    echo "  No sessions."
    return
  fi

  printf "  ${B}%-10s %-16s %-40s %-9s %-8s %s${X}\n" "Status" "User" "Prompt" "Started" "Dur" "Log"
  echo -e "  ${D}$(printf '─%.0s' {1..96})${X}"

  # Process all files at once with jq, pre-sorted by mtime via ls -t
  local count=0
  for f in $(ls -t "$SESSIONS_DIR"/*.json 2>/dev/null); do
    [ $count -ge 20 ] && break
    # Single jq call outputs 6 lines
    local out
    out=$(jq -r '
      .status // "?",
      (.user // "?")[:14],
      ((.prompt // "") | split("\n\n") | last | gsub("\n"; " "))[:38],
      .started // "",
      .finished // "",
      (.log_url // "")[-10:]
    ' "$f" 2>/dev/null) || continue

    local status user prompt started finished log_id
    { read -r status; read -r user; read -r prompt; read -r started; read -r finished; read -r log_id; } <<< "$out"

    local time_str="-" duration="-"
    if [ -n "$started" ]; then
      time_str=$(date -d "$started" +%H:%M:%S 2>/dev/null || echo "-")
      local now_s start_s end_s delta
      now_s=$(date +%s)
      start_s=$(date -d "$started" +%s 2>/dev/null || echo "$now_s")
      end_s=${finished:+$(date -d "$finished" +%s 2>/dev/null || echo "$now_s")}
      end_s=${end_s:-$now_s}
      delta=$((end_s - start_s))
      if [ $delta -ge 3600 ]; then duration="$((delta/3600))h$((delta%3600/60))m"
      elif [ $delta -ge 60 ]; then duration="$((delta/60))m$((delta%60))s"
      else duration="${delta}s"; fi
    fi

    local color="$R"
    case "$status" in running) color="$Y";; completed) color="$G";; esac

    printf "  ${color}%-10s${X} ${C}%-16s${X} %-40s %-9s %-8s ${D}%s${X}\n" \
      "$status" "$user" "$prompt" "$time_str" "$duration" "$log_id"
    count=$((count + 1))
  done
}

if [[ "${1:-}" == "--once" ]]; then
  render
else
  trap 'printf "\033[?25h"; exit 0' INT TERM
  printf "\033[?25l"
  while true; do
    clear
    render
    echo -e "\n  ${D}Refreshing every 3s (Ctrl+C to exit)${X}"
    sleep 3
  done
fi
