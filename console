#!/usr/bin/env python3
"""
ClaudeBox Console — shows active and recent sessions.

Usage: ./console [--watch]
"""

import json
import glob
import os
import subprocess
import sys
import time
from datetime import datetime

SESSIONS_DIR = os.path.join(
    os.environ.get("CLAUDE_REPO_DIR", os.path.expanduser("~/aztec-packages")),
    ".claude", "claudebox", "sessions",
)

# ANSI colors
BOLD = "\033[1m"
DIM = "\033[2m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
CYAN = "\033[36m"
RESET = "\033[0m"


def load_sessions():
    """Load all session JSON files."""
    sessions = []
    for path in glob.glob(os.path.join(SESSIONS_DIR, "*.json")):
        try:
            with open(path) as f:
                s = json.load(f)
            s["_file"] = path
            sessions.append(s)
        except (json.JSONDecodeError, IOError):
            pass
    # Sort by start time, newest first
    sessions.sort(key=lambda s: s.get("started", ""), reverse=True)
    return sessions


def format_time(iso_str):
    """Format ISO timestamp to short form."""
    if not iso_str:
        return "-"
    try:
        dt = datetime.fromisoformat(iso_str)
        return dt.strftime("%H:%M:%S")
    except Exception:
        return iso_str[:19]


def format_duration(started, finished):
    """Calculate and format duration."""
    if not started:
        return "-"
    try:
        start = datetime.fromisoformat(started)
        end = datetime.fromisoformat(finished) if finished else datetime.now().astimezone()
        delta = end - start
        mins, secs = divmod(int(delta.total_seconds()), 60)
        if mins > 0:
            return f"{mins}m{secs}s"
        return f"{secs}s"
    except Exception:
        return "-"


def status_color(status):
    if status == "running":
        return YELLOW
    if status == "completed":
        return GREEN
    return RED


def check_slack_listener():
    """Check if the slack listener process is running."""
    try:
        result = subprocess.run(
            ["pgrep", "-f", "slack-listener.py"],
            capture_output=True, text=True
        )
        return result.returncode == 0
    except Exception:
        return False


def render(sessions):
    """Render the console output."""
    lines = []
    lines.append(f"\n{BOLD}ClaudeBox Console{RESET}")
    lines.append(f"{DIM}{'─' * 120}{RESET}")

    # Slack listener status
    slack_running = check_slack_listener()
    if slack_running:
        lines.append(f"  Slack listener: {GREEN}running{RESET}")
    else:
        lines.append(f"  Slack listener: {RED}not running{RESET}")
    lines.append("")

    if not sessions:
        lines.append("  No sessions found.")
        lines.append(f"  Sessions dir: {SESSIONS_DIR}")
        return "\n".join(lines)

    # Header
    lines.append(
        f"  {BOLD}{'Status':<12} {'User':<18} {'Prompt':<40} "
        f"{'Started':<10} {'Duration':<10} {'Link'}{RESET}"
    )
    lines.append(f"  {'─' * 116}")

    for s in sessions[:20]:  # Show last 20
        status = s.get("status", "unknown")
        color = status_color(status)
        user = s.get("user", "unknown")[:16]
        prompt = s.get("prompt", "")
        # Strip thread context prefix to show only the user's actual prompt
        if "Slack thread context:" in prompt:
            prompt = prompt.split("\n\n", 1)[-1]
        prompt = prompt.replace("\n", " ")[:38]
        started = format_time(s.get("started"))
        duration = format_duration(s.get("started"), s.get("finished"))

        link = s.get("link", "-")

        lines.append(
            f"  {color}{status:<12}{RESET} {CYAN}{user:<18}{RESET} {prompt:<40} "
            f"{started:<10} {duration:<10} {DIM}{link}{RESET}"
        )

    running = sum(1 for s in sessions if s.get("status") == "running")
    lines.append(f"\n  {BOLD}{running}{RESET} running, {BOLD}{len(sessions)}{RESET} total")
    return "\n".join(lines)


def main():
    watch = "--watch" in sys.argv or "-w" in sys.argv

    if watch:
        try:
            while True:
                os.system("clear")
                sessions = load_sessions()
                print(render(sessions))
                print(f"\n  {DIM}Refreshing every 5s... (Ctrl+C to exit){RESET}")
                time.sleep(5)
        except KeyboardInterrupt:
            print()
    else:
        sessions = load_sessions()
        print(render(sessions))


if __name__ == "__main__":
    main()
