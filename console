#!/usr/bin/env bash
# ClaudeBox Console — live-updating session dashboard.
# Usage: ./console        (live, refreshes every 3s)
#        ./console --once  (print once and exit)
set -uo pipefail

SESSIONS_DIR="${CLAUDE_REPO_DIR:-$HOME/aztec-packages}/.claude/claudebox/sessions"
B='\033[1m' D='\033[2m' G='\033[32m' Y='\033[33m' R='\033[31m' C='\033[36m' X='\033[0m'

render() {
  echo -e "\n${B}ClaudeBox Console${X}"
  echo -e "${D}$(printf '─%.0s' {1..100})${X}"

  if systemctl --user is-active claudebox-slack.service &>/dev/null; then
    echo -e "  Server: ${G}running${X}"
  else
    echo -e "  Server: ${R}stopped${X}"
  fi

  local containers
  containers=$(docker ps --filter "name=claudebox-" --format '{{.Names}}' 2>/dev/null | grep -vc '^claudebox-sidecar' || true)
  echo -e "  Active: ${B}${containers}${X} containers"
  echo ""

  local files
  files=$(ls -t "$SESSIONS_DIR"/*.json 2>/dev/null) || true
  if [ -z "$files" ]; then
    echo "  No sessions."
    return
  fi

  printf "  ${B}%-10s %-16s %-40s %-9s %-8s %s${X}\n" "Status" "User" "Prompt" "Started" "Dur" "Log"
  echo -e "  ${D}$(printf '─%.0s' {1..96})${X}"

  # Get list of actually-running Docker containers (one docker call for all)
  local running_containers
  running_containers=$(docker ps --filter "name=claudebox-" --format '{{.Names}}' 2>/dev/null || true)

  # Single jq call processes all files, outputs one tab-delimited line per session
  local now_s
  now_s=$(date +%s)
  echo "$files" | xargs jq -r --argjson now "$now_s" '
    def norm: sub("\\.[0-9]+"; "") | sub("\\+00:00$"; "Z");
    def dur(s; e):
      if s == null then "-"
      else
        ((if e then (e | norm | fromdateiso8601) else $now end) - (s | norm | fromdateiso8601)) as $d |
        if $d >= 3600 then "\($d/3600|floor)h\($d%3600/60|floor)m"
        elif $d >= 60 then "\($d/60|floor)m\($d%60|floor)s"
        else "\($d)s" end
      end;
    def ts: if . then (norm | fromdateiso8601 | strftime("%H:%M:%S")) else "-" end;
    [
      .status // "?",
      (.user // "?")[:14],
      ((.prompt // "") | split("\n\n") | last | gsub("\n"; " "))[:38],
      (.started | ts),
      dur(.started; .finished),
      (.log_url // "")[-10:],
      .container // ""
    ] | @tsv
  ' 2>/dev/null | while IFS=$'\t' read -r status user prompt started duration log_id container; do
    # Cross-reference: if metadata says "running" but container is gone/missing, show "stale"
    if [ "$status" = "running" ]; then
      if [ -z "$container" ] || ! echo "$running_containers" | grep -qF "$container"; then
        status="stale"
      fi
    fi
    local color="$R"
    case "$status" in running) color="$Y";; completed) color="$G";; cancelled) color="$D";; esac
    printf "  ${color}%-10s${X} ${C}%-16s${X} %-40s %-9s %-8s ${D}%s${X}\n" \
      "$status" "$user" "$prompt" "$started" "$duration" "$log_id"
  done
}

if [[ "${1:-}" == "--once" ]]; then
  render
else
  trap 'printf "\033[?25h"; exit 0' INT TERM
  printf "\033[?25l"
  while true; do
    clear
    render
    echo -e "\n  ${D}Refreshing every 3s (Ctrl+C to exit)${X}"
    sleep 3
  done
fi
